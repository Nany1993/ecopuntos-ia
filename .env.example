# ECOPUNTOS IA — configuracion local (copiar a .env)

# Telegram Bot (obligatorio) — crear en @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=TuBotDeTelegram

# Gemini (obligatorio) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI GPT (opcional, respaldo)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Base de datos: sqlite | supabase
DATABASE_BACKEND=sqlite
SQLITE_PATH=data/smartsort.db

# Supabase (solo si DATABASE_BACKEND=supabase)
# Reactiva tu proyecto en https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_KEY=

# Parámetros de sesión (valores del piloto)
MAXIMO_INTENTOS=3
TIEMPO_REINTENTO_SEG=300
TIEMPO_MAXIMO_SESION_MIN=10
NIVEL_CONFIANZA_MINIMO=0.6
SLA_RESPUESTA_SEG=5

# EcoPuntos
PUNTOS_ACIERTO_PRIMERA=10
